{
  "name": "@licensebox/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:create": "dotenv -e ../../.env -- prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "db:migrate:resolve": "dotenv -e ../../.env -- prisma migrate resolve",
    "db:migrate:history": "dotenv -e ../../.env -- prisma migrate status",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:generate:prod": "prisma generate",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed.ts",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\""
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "prisma": "6.19.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3"
  }
}
